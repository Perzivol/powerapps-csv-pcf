{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "obj/selftest",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "test/xlsxImport.selftest.ts",
    "test/xlsxFixture.ts",
    "scripts/make-sample-xlsx.ts",
    "CsvLineItemImport/lineItemParser.ts",
    "CsvLineItemImport/xlsxReader.ts"
  ]
}
